<Project Sdk="Godot.NET.Sdk/4.5.1">
	<PropertyGroup>
		<!-- 如果你安装了 10.0 并遇到问题，改这里 -->
		<TargetFramework>net9.0</TargetFramework>
		<ImplicitUsings>true</ImplicitUsings>
		<LangVersion>12.0</LangVersion>
		<Nullable>enable</Nullable>
		<AllowUnsafeBlocks>true</AllowUnsafeBlocks>
		<EnableDynamicLoading>true</EnableDynamicLoading>

		<!-- 改成你的杀戮尖塔 2 目录 -->
		<Sts2Dir>D:\Steam\steamapps\common\Slay the Spire 2</Sts2Dir>
		<Sts2DataDir>$(Sts2Dir)\data_sts2_windows_x86_64</Sts2DataDir>
		<SecondarySts2Dir Condition="'$(SecondarySts2Dir)' == '' and Exists('D:\SteamLibrary\steamapps\common\Slay the Spire 2')">D:\SteamLibrary\steamapps\common\Slay the Spire 2</SecondarySts2Dir>
		<GodotExportPreset>Windows Desktop</GodotExportPreset>
		<ModOutputDir>$(Sts2Dir)\mods\$(MSBuildProjectName)\</ModOutputDir>
		<SecondaryModOutputDir Condition="'$(SecondarySts2Dir)' != ''">$(SecondarySts2Dir)\mods\$(MSBuildProjectName)\</SecondaryModOutputDir>
		<PckOutputPath>$(ModOutputDir)$(MSBuildProjectName).pck</PckOutputPath>
		<GodotEditorPath Condition="'$(GodotEditorPath)' == '' and Exists('D:\MOD\杀戮尖塔2mod制作\megadot-4.5.1-m.8-windows-x86_64-llvm-editor-csharp\MegaDot_v4.5.1-stable_mono_win64.exe')">D:\MOD\杀戮尖塔2mod制作\megadot-4.5.1-m.8-windows-x86_64-llvm-editor-csharp\MegaDot_v4.5.1-stable_mono_win64.exe</GodotEditorPath>
	</PropertyGroup>

	<PropertyGroup>
		<RunPckExport Condition="'$(RunPckExport)' == '' and '$(DesignTimeBuild)' != 'true'">true</RunPckExport>
		<RunPckExport Condition="'$(RunPckExport)' == ''">false</RunPckExport>
	</PropertyGroup>

	<Target Name="ValidateChineseLocalization" BeforeTargets="BeforeBuild">
		<Exec Command="powershell -NoProfile -ExecutionPolicy Bypass -File &quot;$(MSBuildProjectDirectory)\tools\ValidateLocalization.ps1&quot; -LocalizationDir &quot;$(MSBuildProjectDirectory)\ReAstralPartyMod\localization\zhs&quot;"/>
	</Target>

	<ItemGroup>
		<Reference Include="sts2">
			<HintPath>$(Sts2DataDir)\sts2.dll</HintPath>
			<Private>true</Private>
		</Reference>

		<Reference Include="0Harmony">
			<HintPath>$(Sts2DataDir)\0Harmony.dll</HintPath>
			<Private>true</Private>
		</Reference>

		<!-- 本地引用，注意路径是否正确 -->
		<Reference Include="STS2-RitsuLib">
			<HintPath>$(Sts2Dir)/mods/RitsuLib/STS2-RitsuLib.dll</HintPath>
			<Private>true</Private>
		</Reference>

		<!-- NuGet 获取，注意版本是否一致，不一致手动更改 Version -->
		<!-- <PackageReference Include="STS2.RitsuLib" Version="*" /> -->
	</ItemGroup>

	<ItemGroup>
		<None Update="ReAstralPartyMod\**\*">
			<Visible>true</Visible>
		</None>
	</ItemGroup>

