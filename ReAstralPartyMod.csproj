	<Target Name="ExportModPck" AfterTargets="Build" Condition="'$(RunPckExport)' == 'true' and '$(STS2_SKIP_PCK_EXPORT)' != '1' and Exists('$(GodotEditorPath)')">
		<Message Text="Exporting mod pck to $(PckOutputPath)..." Importance="high"/>
		<MakeDir Directories="$(ModOutputDir)"/>
		<Exec
				WorkingDirectory="$(MSBuildProjectDirectory)"
				Command="&quot;$(GodotEditorPath)&quot; --headless --path &quot;$(MSBuildProjectDirectory)&quot; --export-pack &quot;$(GodotExportPreset)&quot; &quot;$(PckOutputPath)&quot;"
				EnvironmentVariables="STS2_SKIP_PCK_EXPORT=1"
				IgnoreExitCode="true"
				IgnoreStandardErrorWarningFormat="true"/>
		<Error Condition="!Exists('$(PckOutputPath)')" Text="Godot export did not produce $(PckOutputPath)."/>
	</Target>

	<Target Name="WarnMissingGodot" AfterTargets="Build" Condition="'$(RunPckExport)' == 'true' and '$(STS2_SKIP_PCK_EXPORT)' != '1' and !Exists('$(GodotEditorPath)')">
		<Warning Text="Godot executable not found at $(GodotEditorPath). Skipped PCK export."/>
	</Target>

	<!-- 自动复制 dll 和 json -->
	<Target Name="CopyModArtifacts" AfterTargets="Build" DependsOnTargets="ExportModPck">
		<Message Text="Copying mod to Slay the Spire 2 mods folder..." Importance="high"/>
		<MakeDir Directories="$(ModOutputDir)"/>
		<Copy SourceFiles="$(TargetPath)" DestinationFolder="$(ModOutputDir)\"/>
		<Copy SourceFiles="$(MSBuildProjectName).json" DestinationFolder="$(ModOutputDir)\"/>
		<Copy Condition="Exists('$(PckOutputPath)')" SourceFiles="$(PckOutputPath)" DestinationFolder="$(ModOutputDir)\"/>

		<Message Condition="'$(SecondaryModOutputDir)' != '' and '$(SecondaryModOutputDir)' != '$(ModOutputDir)'" Text="Copying mod to secondary Slay the Spire 2 mods folder..." Importance="high"/>
		<MakeDir Condition="'$(SecondaryModOutputDir)' != '' and '$(SecondaryModOutputDir)' != '$(ModOutputDir)'" Directories="$(SecondaryModOutputDir)"/>
		<Copy Condition="'$(SecondaryModOutputDir)' != '' and '$(SecondaryModOutputDir)' != '$(ModOutputDir)'" SourceFiles="$(TargetPath)" DestinationFolder="$(SecondaryModOutputDir)\"/>
		<Copy Condition="'$(SecondaryModOutputDir)' != '' and '$(SecondaryModOutputDir)' != '$(ModOutputDir)'" SourceFiles="$(MSBuildProjectName).json" DestinationFolder="$(SecondaryModOutputDir)\"/>
		<Copy Condition="'$(SecondaryModOutputDir)' != '' and '$(SecondaryModOutputDir)' != '$(ModOutputDir)' and Exists('$(PckOutputPath)')" SourceFiles="$(PckOutputPath)" DestinationFolder="$(SecondaryModOutputDir)\"/>
	</Target>
</Project>
